# ── Server ───────────────────────────────────────────────────
PORT=5000

# ── RapidAPI ─────────────────────────────────────────────────
# ONE key works for ALL 4 APIs below
# Get it from: rapidapi.com → avatar → My Apps → copy key
RAPIDAPI_KEY=your_rapidapi_key_here

# APIs you need to subscribe to on RapidAPI (all free tier):
# 1. Real-Time Amazon Data       → real-time-amazon-data.p.rapidapi.com
# 2. Real-Time Flipkart Data 2   → real-time-flipkart-data2.p.rapidapi.com
# 3. Real-Time eBay Data         → real-time-ebay-data.p.rapidapi.com
# 4. Real-Time Product Search    → real-time-product-search.p.rapidapi.com
#    (covers Croma, Myntra, Nykaa, AJIO, Meesho, Snapdeal, JioMart + more)

# ── Supabase ─────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── OAuth ─────────────────────────────────────────────────────
# Where to redirect after Google sign-in
# Local dev: http://localhost:5173  (or wherever you serve frontend)
# Production: https://your-github-username.github.io/price-compare
FRONTEND_URL=http://localhost:5173
